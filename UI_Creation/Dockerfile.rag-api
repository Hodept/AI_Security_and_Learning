FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY UI_Creation/requirements-rag-api.txt /tmp/requirements-rag-api.txt
COPY UI_Creation/requirements-streamlit.txt /tmp/requirements-streamlit.txt
RUN python -m pip install --upgrade pip \
    && python -m pip install \
        -r /tmp/requirements-rag-api.txt \
        -r /tmp/requirements-streamlit.txt

COPY . /app

EXPOSE 8000
EXPOSE 8501
